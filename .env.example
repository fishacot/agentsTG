# Multi-Bot System: 6 Agents + 1 Orchestrator
# Human names: Егор (Оркестратор), Эльза (Ассистент), Руслан (Кодер),
#              Ульяна (Исследователь), Артём (Безопасность),
#              Ваня (Бизнес), Тася (Маркетолог)
# Get tokens from @BotFather

# Егор — Оркестратор, координирует команду (@egor_orchestrator_bot)
BOT_TOKEN_ORCHESTRATOR=123456:ABC-your-token-here

# Эльза — Ассистент, задачи, календарь (@elliza_pa_bot)
BOT_TOKEN_PA=123456:ABC-your-token-here

# Руслан — Кодер, архитектура, код-ревью (@ruslan_coder_bot)
BOT_TOKEN_CODER=123456:ABC-your-token-here

# Ульяна — Исследователь, поиск, аналитика (@ulyana_research_bot)
BOT_TOKEN_RESEARCH=123456:ABC-your-token-here

# Артём — Безопасность, аудит, CVE (@artem_security_bot)
BOT_TOKEN_SECURITY=123456:ABC-your-token-here

# Ваня — Бизнес, стратегия, MVP (@aivanya_business_bot)
BOT_TOKEN_BUSINESS=123456:ABC-your-token-here

# Тася — Маркетолог, контент, рост (@tasya_marketing_bot)
BOT_TOKEN_MARKETING=123456:ABC-your-token-here

# Group chat where all bots collaborate (get ID from @getidsbot)
GROUP_CHAT_ID=-1001234567890

# Qwen API (OpenAI-compatible via HuggingFace)
QWEN_API_KEY=your_qwen_api_key_here
QWEN_API_BASE=https://api-inference.huggingface.co/models/Qwen/Qwen2.5-72B-Instruct/v1
QWEN_MODEL=Qwen/Qwen2.5-72B-Instruct

# Mem0 for long-term memory (optional)
MEM0_API_KEY=

# PostgreSQL (optional for MVP)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agents_tg

# Redis (optional for MVP)
REDIS_URL=redis://localhost:6379/0

# Obsidian vault for notes
OBSIDIAN_VAULT_PATH=./vault
GIT_REMOTE_URL=

# App Settings
DEBUG=false
LOG_LEVEL=INFO
