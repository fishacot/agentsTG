# Multi-Bot System: 6 Agents + 1 Orchestrator
# Human names: Егор (Оркестратор), Эльза (Ассистент), Руслан (Кодер),
#              Ульяна (Исследователь), Артём (Безопасность),
#              Ваня (Бизнес), Тася (Маркетолог)
# Get tokens from @BotFather

# Егор — Оркестратор, координирует команду (@egor_orchestrator_bot)
BOT_TOKEN_ORCHESTRATOR=123456:ABC-your-token-here

# Эльза — Ассистент, задачи, календарь (@elliza_pa_bot)
BOT_TOKEN_PA=123456:ABC-your-token-here

# Руслан — Кодер, архитектура, код-ревью (@ruslan_coder_bot)
BOT_TOKEN_CODER=123456:ABC-your-token-here

# Ульяна — Исследователь, поиск, аналитика (@ulyana_research_bot)
BOT_TOKEN_RESEARCH=123456:ABC-your-token-here

# Артём — Безопасность, аудит, CVE (@artem_security_bot)
BOT_TOKEN_SECURITY=123456:ABC-your-token-here

# Ваня — Бизнес, стратегия, MVP (@aivanya_business_bot)
BOT_TOKEN_BUSINESS=123456:ABC-your-token-here

# Тася — Маркетолог, контент, рост (@tasya_marketing_bot)
BOT_TOKEN_MARKETING=123456:ABC-your-token-here

# Group chat where all bots collaborate (get ID from @getidsbot)
GROUP_CHAT_ID=-1001234567890

# Private Telegram channel for Elza notes (see deploy/NOTES_CHANNEL.md)
NOTES_CHANNEL_ID=-1001234567890

# Groq API (fallback — free tier: https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_BASE=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.1-8b-instant

# Google Gemini (recommended primary — free tier: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta/openai
GEMINI_MODEL=gemini-2.5-flash

# Provider fallback order (comma-separated)
# Provider fallback order. On VPS use groq only (Gemini blocks datacenter IPs).
LLM_PROVIDER_CHAIN=groq

# Hugging Face (optional tertiary fallback)
QWEN_API_KEY=
QWEN_API_BASE=https://router.huggingface.co/v1/chat/completions
QWEN_MODEL=Qwen/Qwen2.5-7B-Instruct

# Optional per-agent overrides (defaults in src/agents_tg/services/agent_models.py):
# MODEL_ORCHESTRATOR=llama-3.3-70b-versatile
# MODEL_PERSONAL_ASSISTANT=llama-3.1-8b-instant
# MODEL_CODER=qwen/qwen3-32b
# MODEL_RESEARCH=llama-3.1-8b-instant
# MODEL_SECURITY=llama-3.1-8b-instant
# MODEL_BUSINESS=llama-3.1-8b-instant
# MODEL_MARKETING=llama-3.1-8b-instant

# Mem0 for long-term memory (optional)
MEM0_API_KEY=

# PostgreSQL (optional for MVP)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/agents_tg

# Redis (optional for MVP)
REDIS_URL=redis://localhost:6379/0

# Obsidian vault for notes
OBSIDIAN_VAULT_PATH=./vault
GIT_REMOTE_URL=

# App Settings
DEBUG=false
LOG_LEVEL=INFO
APP_TIMEZONE=Europe/Moscow
HEALTH_PORT=8080
MESSAGE_DEBOUNCE_MS=2000
LLM_COOLDOWN_SEC=3.0

# Proactive agent wake (OpenClaw heartbeat)
HEARTBEAT_ENABLED=true
HEARTBEAT_INTERVAL_MIN=60
HEARTBEAT_QUIET_HOURS=12
HEARTBEAT_SKIP_IF_BUSY_MIN=5
HEARTBEAT_DIGEST_LLM=true

# Neon (cloud Postgres) — see deploy/NEON_SETUP.md
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Upstash Redis (optional) — dedupe, run lock, LLM cooldown
# REDIS_URL=rediss://default:token@host:6379
