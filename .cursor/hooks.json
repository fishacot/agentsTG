{
  "version": 1,
  "hooks": {
    "afterFileEdit": [
      {
        "command": "python .cursor/hooks/ruff_after_py_edit.py",
        "timeout": 45
      }
    ],
    "beforeShellExecution": [
      {
        "command": "python .cursor/hooks/guard_destructive_shell.py",
        "timeout": 10
      }
    ],
    "stop": [
      {
        "command": "python .cursor/hooks/stop_verify_reminder.py",
        "timeout": 15
      }
    ]
  }
}
